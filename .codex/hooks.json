{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agents/hooks/test-quality-reminder.py\"",
            "statusMessage": "Checking test run + vetting"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agents/hooks/spec-quality-reminder.py\"",
            "statusMessage": "Spec-quality reminder"
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agents/hooks/spec-conformance-gate.py\"",
            "statusMessage": "Spec-conformance gate"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agents/hooks/test-quality-reminder.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
